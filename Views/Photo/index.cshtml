@model IEnumerable<PhotoSharingApplication.Models.Photo>
@{
    ViewData["Title"] = "Galerie";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 style="font-size:2rem; font-weight:bold; letter-spacing:-1px">
        Galerie
        <span style="color:#E8593C">.</span>
    </h2>
    <a asp-action="Creer" class="btn-accent btn">+ Ajouter une photo</a>
</div>

<style>
    .photo-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 1.5rem;
    }
    .photo-card {
        background: white;
        border-radius: 4px;
        overflow: hidden;
        box-shadow: 0 2px 12px rgba(0,0,0,0.08);
        transition: transform 0.2s, box-shadow 0.2s;
    }
    .photo-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 24px rgba(0,0,0,0.15);
    }
    .photo-card img {
        width: 100%;
        height: 200px;
        object-fit: cover;
    }
    .photo-card .no-image {
        width: 100%;
        height: 200px;
        background: #f0ece8;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #aaa;
        font-size: 2rem;
    }
    .photo-card-body {
        padding: 1rem 1.2rem;
    }
    .photo-card-body h5 {
        font-size: 1rem;
        font-weight: bold;
        margin-bottom: 4px;
    }
    .photo-card-body .meta {
        font-size: 0.78rem;
        color: #999;
        margin-bottom: 0.8rem;
    }
    .photo-card-body .actions {
        display: flex;
        gap: 8px;
    }
    .btn-sm-outline {
        font-size: 0.75rem;
        padding: 4px 12px;
        border: 1px solid #ddd;
        background: none;
        color: #555;
        border-radius: 2px;
        text-decoration: none;
        transition: all 0.2s;
    }
    .btn-sm-outline:hover {
        background: #1a1a1a;
        color: white;
        border-color: #1a1a1a;
    }
    .btn-sm-danger {
        font-size: 0.75rem;
        padding: 4px 12px;
        border: 1px solid #E8593C;
        background: none;
        color: #E8593C;
        border-radius: 2px;
        text-decoration: none;
        transition: all 0.2s;
    }
    .btn-sm-danger:hover {
        background: #E8593C;
        color: white;
    }
</style>

@if (!Model.Any())
{
    <div style="text-align:center; padding:4rem; color:#aaa;">
        <div style="font-size:3rem">📷</div>
        <p>Aucune photo pour le moment.</p>
        <a asp-action="Creer" class="btn-accent btn mt-2">Ajouter la première photo</a>
    </div>
}
else
{
    <div class="photo-grid">
        @foreach (var item in Model)
        {
            <div class="photo-card">
                @if (item.PhotoFile != null)
                {
                    <img src="@Url.Action("GetImage", "Photo", new { id = item.PhotoID })"
                         alt="@item.Titre" />
                }
                else
                {
                    <div class="no-image">📷</div>
                }
                <div class="photo-card-body">
                    <h5>@item.Titre</h5>
                    <div class="meta">
                        @item.NomUtilisateur · @item.CreerDate.ToString("dd MMM yyyy")
                    </div>
                    <div class="actions">
                        <a asp-action="Afficher"
                           asp-route-id="@item.PhotoID"
                           class="btn-sm-outline">Voir</a>
                        <a asp-action="Delete"
                           asp-route-id="@item.PhotoID"
                           class="btn-sm-danger">Supprimer</a>
                    </div>
                </div>
            </div>
        }
    </div>
}